    },
    {
      "@type": "PropertyValue",
      "name": "NO2 AQI Value",
      "description": "AQI sub-index for Nitrogen Dioxide"
    },
    {
      "@type": "PropertyValue",
      "name": "PM2.5 AQI Value",
      "description": "AQI sub-index for fine particulate matter PM2.5"
    }
  ],
